# Copy this to .env and fill in your values
# Used by docker-compose.yml

# --- Backend ---
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
GEMINI_API_KEY=AIzaSy...
CORS_ORIGIN=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password

# --- Frontend ---
# Must be the public URL of your backend (what the browser hits, not internal)
# Example: http://100.80.147.48:5000  (server IP + backend port)
NEXT_PUBLIC_API_URL=http://100.80.147.48:5000
