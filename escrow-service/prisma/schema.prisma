// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  employer
  freelancer
}

enum ProjectStatus {
  pending
  active
  completed
  cancelled
  disputed
}

enum MilestoneStatus {
  pending
  in_progress
  completed
  approved
  rejected
  paid
}

enum PaymentEventType {
  escrow_hold
  milestone_release
  prorated_release
  refund
}

enum DisputeStatus {
  open
  resolved
  escalated
}

// Models
model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  role           UserRole
  walletBalance  Decimal       @default(0.00) @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())
  
  // Relations
  clientProjects       Project[]       @relation("ProjectClient")
  freelancerProjects   Project[]       @relation("ProjectFreelancer")
  paymentEvents        PaymentEvent[]
  pfiEvents            PFIEvent[]
  
  @@map("users")
}

model Project {
  id                   String        @id @default(cuid())
  clientId             String
  freelancerId         String?
  title                String
  totalBudget          Decimal       @db.Decimal(10, 2)
  escrowBalance        Decimal       @default(0.00) @db.Decimal(10, 2)
  stripePaymentIntentId String?
  status               ProjectStatus @default(pending)
  createdAt            DateTime      @default(now())
  
  // Relations
  client              User            @relation("ProjectClient", fields: [clientId], references: [id])
  freelancer          User?           @relation("ProjectFreelancer", fields: [freelancerId], references: [id])
  clientBrief         ClientBrief?
  milestoneChecks     MilestoneCheck[]
  paymentEvents       PaymentEvent[]
  disputes            Dispute[]
  
  // Indexes
  @@index([clientId])
  @@index([freelancerId])
  @@map("projects")
}

model MilestoneCheck {
  id            String           @id @default(cuid())
  projectId     String
  title         String
  paymentAmount Decimal          @db.Decimal(10, 2)
  status        MilestoneStatus  @default(pending)
  deadline      DateTime
  createdAt     DateTime         @default(now())
  
  // Relations
  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions        Submission[]
  verificationChecks VerificationCheck[]
  paymentEvents      PaymentEvent[]
  
  // Indexes
  @@index([projectId])
  @@map("milestone_checks")
}

model Submission {
  id              String       @id @default(cuid())
  milestoneCheckId String
  content         String
  submittedAt     DateTime     @default(now())
  
  // Relations
  milestoneCheck MilestoneCheck @relation(fields: [milestoneCheckId], references: [id], onDelete: Cascade)
  aqaResult      AQAResult?
  
  @@map("submissions")
}

model AQAResult {
  id           String   @id @default(cuid())
  submissionId String   @unique
  score        Int
  feedback     String
  processedAt  DateTime @default(now())
  
  // Relations
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  auditReport AuditReport?
  
  @@map("aqa_results")
}

model AuditReport {
  id          String   @id @default(cuid())
  aqaResultId String   @unique
  report      String
  createdAt   DateTime @default(now())
  
  // Relations
  aqaResult AQAResult @relation(fields: [aqaResultId], references: [id], onDelete: Cascade)
  
  @@map("audit_reports")
}

model PaymentEvent {
  id              String            @id @default(cuid())
  projectId       String?
  milestoneCheckId String?
  fromUser        String
  toUser          String
  amount          Decimal           @db.Decimal(10, 2)
  type            PaymentEventType
  createdAt       DateTime          @default(now())
  
  // Relations
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneCheck MilestoneCheck? @relation(fields: [milestoneCheckId], references: [id], onDelete: Cascade)
  sender         User            @relation("SentPayments", fields: [fromUser], references: [id])
  recipient      User            @relation("ReceivedPayments", fields: [toUser], references: [id])
  
  // Indexes
  @@index([projectId])
  @@index([milestoneCheckId])
  @@index([fromUser])
  @@index([toUser])
  @@map("payment_events")
}

model Dispute {
  id        String        @id @default(cuid())
  projectId String
  reason    String
  status    DisputeStatus @default(open)
  createdAt DateTime      @default(now())
  
  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("disputes")
}

model ClientBrief {
  id        String   @id @default(cuid())
  projectId String   @unique
  brief     String
  createdAt DateTime @default(now())
  
  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("client_briefs")
}

model SOP {
  id        String   @id @default(cuid())
  content   String
  version   String
  createdAt DateTime @default(now())
  
  @@map("sops")
}

model VerificationContract {
  id        String   @id @default(cuid())
  sopId     String
  terms     String
  createdAt DateTime @default(now())
  
  @@map("verification_contracts")
}

model VerificationCheck {
  id              String        @id @default(cuid())
  milestoneCheckId String
  status          String
  checkedAt       DateTime      @default(now())
  
  // Relations
  milestoneCheck MilestoneCheck @relation(fields: [milestoneCheckId], references: [id], onDelete: Cascade)
  
  @@map("verification_checks")
}

model PFIEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  data      String
  createdAt DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("pfi_events")
}

model AIRequest {
  id        String   @id @default(cuid())
  type      String
  payload   String
  createdAt DateTime @default(now())
  
  @@map("ai_requests")
}

model AIResponse {
  id         String   @id @default(cuid())
  requestId  String   @unique
  response   String
  confidence Float
  createdAt  DateTime @default(now())
  
  @@map("ai_responses")
}
